<?xml version="1.0" encoding="ISO-8859-1"?>
<neuroml xmlns="http://www.neuroml.org/schema/neuroml2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.neuroml.org/schema/neuroml2 https://raw.github.com/NeuroML/NeuroML2/development/Schemas/NeuroML2/NeuroML_v2beta4.xsd" id="kdrcr">

    <ionChannel id="kdrcr" conductance="10pS" type="ionChannelHH" species="k">

        <gate id="n" type="gateHHrates" instances="4">
            <forwardRate type="HHExpLinearRate" rate="0.45per_ms" scale="25.0mV" midpoint="13.0mV"/>
            <reverseRate type="HHExpLinearRate" rate="0.0648per_ms" scale="-12mV" midpoint="23mV"/>
        </gate>
                            
    </ionChannel>

</neuroml>