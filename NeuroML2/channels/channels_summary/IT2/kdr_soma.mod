    n_timeCourse_TIME_SCALE = 1 (ms)       : was: 0.001 (time)
    n_timeCourse_VOLT_SCALE = 1 (mV)       : was: 0.001 (voltage)
    n_timeCourse_nmax = 20 (ms)            : was: 0.02 (time)
    n_timeCourse_Celsius = 24              : was: 24.0 (none)
