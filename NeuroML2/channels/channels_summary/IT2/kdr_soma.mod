    g (uS)                                  : derived variable
    rate_n_q (/ms)
    
}

STATE {
    n_q  : dimension: none
    
}

INITIAL {
    ek = -104.0
    
    temperature = celsius + 273.15
    
    rates()
    rates() ? To ensure correct initialisation.
    
    n_q = n_inf
    
}

BREAKPOINT {
    
    SOLVE states METHOD cnexp
    
    ? DerivedVariable is based on path: conductanceScaling[*]/factor, on: Component(id=kdr_soma type=ionChannelHH), from conductanceScaling; null
    ? Path not present in component, using factor: 1
    
    conductanceScale = 1 
    
    ? DerivedVariable is based on path: gates[*]/fcond, on: Component(id=kdr_soma type=ionChannelHH), from gates; Component(id=n type=gateHHtauInf)
    ? multiply applied to all instances of fcond in: <gates> ([Component(id=n type=gateHHtauInf)]))
    fopen0 = n_fcond ? path based, prefix = 
    
    fopen = conductanceScale  *  fopen0 ? evaluable
    g = conductance  *  fopen ? evaluable
    gion = gmax * fopen 
    
    ik = gion * (v - ek)
    i__kdr_soma =  -1 * ik : set this variable to the current also - note -1 as channel current convention for LEMS used!
    
}

DERIVATIVE states {
    rates()
    n_q' = rate_n_q 
    
}

PROCEDURE rates() {
    
    n_steadyState_V = v /  n_steadyState_VOLT_SCALE ? evaluable
    n_steadyState_x = 1 / (1 + exp(1.e-3* n_steadyState_zetan *( n_steadyState_V - n_steadyState_vhalfn - n_steadyState_sh )*9.648e4/
                (8.315*(273.16+ n_steadyState_Celsius )))) ? evaluable
    n_timeCourse_V = v /  n_timeCourse_VOLT_SCALE ? evaluable
    if (exp(1.e-3* n_timeCourse_zetan * n_timeCourse_gmn *( n_timeCourse_V - n_timeCourse_vhalfn - n_timeCourse_sh )*9.648e4/(8.315*(273.16+ n_timeCourse_Celsius ))) / 
                    ( n_timeCourse_a0n  * (1 + exp(1.e-3* n_timeCourse_zetan *( n_timeCourse_V - n_timeCourse_vhalfn - n_timeCourse_sh )*9.648e4/(8.315*(273.16+ n_timeCourse_Celsius ))))) *  n_timeCourse_TIME_SCALE  <  n_timeCourse_nmax)  { 
        n_timeCourse_t = n_timeCourse_nmax ? evaluable cdv
    } else  { 
        n_timeCourse_t = exp(1.e-3* n_timeCourse_zetan * n_timeCourse_gmn *( n_timeCourse_V - n_timeCourse_vhalfn - n_timeCourse_sh )*9.648e4/(8.315*(273.16+ n_timeCourse_Celsius ))) / 
                    ( n_timeCourse_a0n  * (1 + exp(1.e-3* n_timeCourse_zetan *( n_timeCourse_V - n_timeCourse_vhalfn - n_timeCourse_sh )*9.648e4/(8.315*(273.16+ n_timeCourse_Celsius ))))) *  n_timeCourse_TIME_SCALE ? evaluable cdv
    }
    
    n_q10Settings_q10 = n_q10Settings_q10Factor ^((temperature -  n_q10Settings_experimentalTemp )/ n_q10Settings_TENDEGREES ) ? evaluable
    ? DerivedVariable is based on path: q10Settings[*]/q10, on: Component(id=n type=gateHHtauInf), from q10Settings; Component(id=null type=q10ExpTemp)
    ? multiply applied to all instances of q10 in: <q10Settings> ([Component(id=null type=q10ExpTemp)]))
    n_rateScale = n_q10Settings_q10 ? path based, prefix = n_
    
    n_fcond = n_q ^ n_instances ? evaluable
    ? DerivedVariable is based on path: steadyState/x, on: Component(id=n type=gateHHtauInf), from steadyState; Component(id=null type=kdr_soma_n_inf)
    n_inf = n_steadyState_x ? path based, prefix = n_
    
    ? DerivedVariable is based on path: timeCourse/t, on: Component(id=n type=gateHHtauInf), from timeCourse; Component(id=null type=kdr_soma_n_tau)
    n_tauUnscaled = n_timeCourse_t ? path based, prefix = n_
    
    n_tau = n_tauUnscaled  /  n_rateScale ? evaluable
    
     
    rate_n_q = ( n_inf  -  n_q ) /  n_tau ? Note units of all quantities used here need to be consistent!
    
     
    
     
    
     
    
     
    
}

