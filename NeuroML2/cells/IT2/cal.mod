    m_reverseRate_rate = 0.29000002 (kHz)  : was: 290.0 (per_time)
    m_reverseRate_midpoint = 0 (mV)        : was: 0.0 (voltage)
    m_reverseRate_scale = -10.86 (mV)      : was: -0.01086 (voltage)
    m_timeCourse_TIME_SCALE = 1 (ms)       : was: 0.001 (time)
    m_timeCourse_VOLT_SCALE = 1 (mV)       : was: 0.001 (voltage)
    m_timeCourse_mmin = 0.2 (ms)           : was: 2.0E-4 (time)
    m_timeCourse_a0m = 0.1                 : was: 0.1 (none)
    m_timeCourse_zetam = 2                 : was: 2.0 (none)
    m_timeCourse_gmm = 0.1                 : was: 0.1 (none)
    m_timeCourse_vhalfm = 4                : was: 4.0 (none)
    m_q10Settings_q10Factor = 5            : was: 5.0 (none)
    m_q10Settings_experimentalTemp = 298.15 (K): was: 298.15 (temperature)
    m_q10Settings_TENDEGREES = 10 (K)      : was: 10.0 (temperature)
