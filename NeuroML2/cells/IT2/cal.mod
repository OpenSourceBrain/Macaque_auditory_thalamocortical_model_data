}

PARAMETER {
    
    gmax = 0  (S/cm2)                       : Will be changed when ion channel mechanism placed on cell!
    
    conductance = 1.0E-5 (uS)              : was: 1.0E-11 (conductance)
    ConductanceScalingCaDependent_CONC_SCALE = 1 (mM): was: 1.0 (concentration)
    ConductanceScalingCaDependent_ki = 0.001 : was: 0.001 (none)
    m_instances = 2                        : was: 2.0 (none)
    m_forwardRate_rate = 156.90001 (kHz)   : was: 156900.0 (per_time)
    m_forwardRate_midpoint = 81.5 (mV)     : was: 0.0815 (voltage)
